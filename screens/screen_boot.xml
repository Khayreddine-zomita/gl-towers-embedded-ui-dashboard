<screen name="screen_boot">
	<view
		width="480"
		height="320"
		scrollable="false"
		scrollbar_mode="off"
		style_bg_color="#COLOR_BOOT_BLACK"
		style_bg_opa="255"
		style_pad_all="0"
		style_border_width="0"
		style_radius="0"
	>
		<!-- Main boot logo image -->
		<lv_image
			name="boot_logo_image"
			x="90"
			y="10"
			width="300"
			height="300"
			src="img_gl_towers_logo_1"
			scrollable="false"
			scrollbar_mode="off"
		/>

		<!-- Boot status -->
		<lv_label
			name="boot_status_label"
			x="0"
			y="300"
			width="480"
			text="Initializing System..."
			long_mode="clip"
			style_text_align="center"
			style_text_color="#COLOR_MUTED_GRAY"
			style_text_font="font_inter_11"
		/>
	</view>
</screen>
