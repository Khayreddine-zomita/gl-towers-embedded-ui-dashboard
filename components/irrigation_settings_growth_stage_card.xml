				<lv_label
					name="irrigation_growth_stage_seedling_name_label"
					x="56"
					y="5"
					width="210"
					text="Seedling / Young"
					long_mode="clip"
					style_text_color="#COLOR_TEXT_PRIMARY"
					style_text_font="font_inter_12"
