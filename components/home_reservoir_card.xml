<component>
	<api>
		<prop name="reservoir_value" type="string" />
		<prop name="reservoir_unit_x" type="int" />
		<prop name="reservoir_volume" type="string" />
		<prop name="reservoir_hint" type="string" />
		<prop name="reservoir_level" type="int" />
	</api>

	<view
		width="464"
		height="104"
		scrollable="false"
		scrollbar_mode="off"
		style_bg_color="#COLOR_CARD_BG"
		style_bg_opa="255"
		style_radius="16"
		style_pad_all="0"
		style_border_width="2"
		style_border_color="#COLOR_DIVIDER"
		style_shadow_width="8"
		style_shadow_opa="18"
		style_shadow_color="#COLOR_SHADOW"
		style_shadow_offset_y="3"
	>
		<lv_label
			name="reservoir_title_label"
			x="18"
			y="10"
			width="140"
			text="RESERVOIR"
			long_mode="clip"
			style_text_color="#COLOR_PRIMARY_GREEN"
			style_text_font="font_inter_12"
		/>

		<lv_label
			name="reservoir_percent_label"
			x="18"
			y="36"
			width="80"
			text="$reservoir_value"
			long_mode="clip"
			style_text_color="#COLOR_TEXT_PRIMARY"
			style_text_font="font_inter_26"
		/>

		<lv_label
			name="reservoir_percent_unit_label"
			x="$reservoir_unit_x"
			y="49"
			width="28"
			text="%"
			long_mode="clip"
			style_text_color="#COLOR_TEXT_PRIMARY"
			style_text_font="font_inter_12"
		/>

		<lv_label
			name="reservoir_volume_label"
			x="158"
			y="34"
			width="180"
			text="$reservoir_volume"
			long_mode="clip"
			style_text_color="#COLOR_TEXT_PRIMARY"
			style_text_font="font_inter_12"
		/>

		<lv_label
			name="reservoir_hint_label"
			x="158"
			y="56"
			width="200"
			text="$reservoir_hint"
			long_mode="clip"
			style_text_color="#COLOR_TEXT_MUTED"
			style_text_font="font_inter_12"
		/>

		<lv_image
			name="reservoir_water_icon"
			x="410"
			y="27"
			width="28"
			height="28"
			src="img_home_irrigation"
			scrollable="false"
			scrollbar_mode="off"
			style_image_recolor="#COLOR_STATUS_INFO"
			style_image_recolor_opa="255"
		/>

		<lv_bar
			name="reservoir_level_bar"
			x="18"
			y="82"
			width="428"
			height="8"
			min_value="0"
			max_value="100"
			value="$reservoir_level"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_color="#COLOR_DIVIDER"
			style_bg_opa="255"
			style_radius="4"
			style_border_width="0"
			style_pad_all="0"
		/>
	</view>
</component>
