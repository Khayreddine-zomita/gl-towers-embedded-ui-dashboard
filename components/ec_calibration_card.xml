<component>
	<api>
		<prop name="step_text" type="string" />
		<prop name="current_value" type="string" />
		<prop name="stability_status" type="string" />
		<prop name="instruction_title" type="string" />
		<prop name="instruction_text" type="string" />
	</api>

	<view
		width="452"
		height="217"
		scrollable="false"
		scrollbar_mode="off"
		style_bg_opa="0"
		style_pad_all="0"
		style_border_width="0"
		style_radius="0"
	>
		<lv_label
			name="ec_calibration_title_label"
			x="2"
			y="0"
			width="240"
			text="EC CALIBRATION"
			long_mode="clip"
			style_text_color="#COLOR_PRIMARY_GREEN"
			style_text_font="font_inter_14"
			style_text_letter_space="1"
		/>

		<lv_label
			name="ec_calibration_step_label"
			x="318"
			y="1"
			width="130"
			text="$step_text"
			long_mode="clip"
			style_text_align="right"
			style_text_color="#COLOR_TEXT_SECONDARY"
			style_text_font="font_inter_12"
		/>

		<lv_obj
			name="ec_calibration_card"
			x="0"
			y="24"
			width="452"
			height="193"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_color="#COLOR_CARD_BG"
			style_bg_opa="255"
			style_radius="18"
			style_pad_all="0"
			style_border_width="1"
			style_border_color="#COLOR_DIVIDER"
			style_shadow_width="8"
			style_shadow_opa="16"
			style_shadow_color="#COLOR_SHADOW"
			style_shadow_offset_y="3"
		>
			<!-- Current reading -->
			<lv_label
				name="ec_calibration_current_title_label"
				x="18"
				y="12"
				width="160"
				text="Current reading"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_SECONDARY"
				style_text_font="font_inter_12"
			/>

			<lv_label
				name="ec_calibration_current_value_label"
				x="18"
				y="31"
				width="130"
				text="$current_value"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_PRIMARY"
				style_text_font="font_inter_26"
			/>

			<lv_label
				name="ec_calibration_current_unit_label"
				x="136"
				y="42"
				width="80"
				text="mS/cm"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_SECONDARY"
				style_text_font="font_inter_12"
			/>

			<!-- Stability pill -->
			<lv_obj
				name="ec_calibration_stability_pill"
				x="322"
				y="22"
				width="92"
				height="28"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_LIGHT_GREEN"
				style_bg_opa="255"
				style_radius="14"
				style_border_width="0"
				style_pad_all="0"
			>
				<lv_label
					name="ec_calibration_stability_label"
					x="0"
					y="7"
					width="92"
					text="$stability_status"
					long_mode="clip"
					style_text_align="center"
					style_text_color="#COLOR_PRIMARY_GREEN"
					style_text_font="font_inter_12"
				/>
			</lv_obj>

			<lv_obj
				name="ec_calibration_divider_1"
				x="18"
				y="66"
				width="416"
				height="1"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_DIVIDER"
				style_bg_opa="255"
				style_border_width="0"
				style_pad_all="0"
			/>

			<!-- EC solution selector -->
			<lv_label
				name="ec_calibration_solution_title_label"
				x="18"
				y="79"
				width="160"
				text="EC solution"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_PRIMARY"
				style_text_font="font_inter_12"
			/>

			<lv_dropdown
				name="ec_calibration_solution_dropdown"
				x="272"
				y="73"
				width="142"
				height="30"
				options="1413 uS/cm&#10;5000 uS/cm&#10;12880 uS/cm"
				selected="0"
				symbol="img_simple_chevron_icon_1"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_DARK_FOREST"
				style_bg_opa="255"
				style_radius="10"
				style_border_width="0"
				style_pad_left="10"
				style_pad_right="8"
				style_text_color="#COLOR_WHITE"
				style_text_font="font_inter_11"
				style_image_recolor-indicator="#COLOR_WHITE"
				style_image_recolor_opa-indicator="255"
				style_transform_rotation-indicator="900"
				style_transform_pivot_x-indicator="8"
				style_transform_pivot_y-indicator="8"
			>
				<lv_dropdown-list
					style_bg_color="#COLOR_CARD_BG"
					style_bg_opa="255"
					style_radius="10"
					style_border_width="1"
					style_border_color="#COLOR_DIVIDER"
					style_text_color="#COLOR_TEXT_PRIMARY"
					style_text_font="font_inter_11"
				/>
			</lv_dropdown>

			<lv_obj
				name="ec_calibration_divider_2"
				x="18"
				y="113"
				width="416"
				height="1"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_DIVIDER"
				style_bg_opa="255"
				style_border_width="0"
				style_pad_all="0"
			/>

			<!-- Instruction block -->
			<lv_label
				name="ec_calibration_instruction_title_label"
				x="18"
				y="126"
				width="300"
				text="$instruction_title"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_PRIMARY"
				style_text_font="font_inter_12"
			/>

			<lv_label
				name="ec_calibration_instruction_text_label"
				x="18"
				y="147"
				width="396"
				height="34"
				text="$instruction_text"
				long_mode="wrap"
				style_text_color="#COLOR_TEXT_SECONDARY"
				style_text_font="font_inter_11"
			/>
		</lv_obj>
	</view>
</component>
