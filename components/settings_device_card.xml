<component>
	<api>
		<prop name="device_name" type="string" />
		<prop name="model_name" type="string" />
		<prop name="serial_number" type="string" />
		<prop name="firmware_version" type="string" />
	</api>

	<view
		width="452"
		height="226"
		scrollable="false"
		scrollbar_mode="off"
		style_bg_opa="0"
		style_pad_all="0"
		style_border_width="0"
		style_radius="0"
	>
		<lv_label
			name="settings_device_title_label"
			x="2"
			y="0"
			width="260"
			text="DEVICE"
			long_mode="clip"
			style_text_color="#COLOR_PRIMARY_GREEN"
			style_text_font="font_inter_14"
			style_text_letter_space="1"
		/>

		<!-- Device info card -->
		<lv_obj
			name="settings_device_info_card"
			x="0"
			y="24"
			width="452"
			height="108"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_color="#COLOR_CARD_BG"
			style_bg_opa="255"
			style_radius="16"
			style_pad_all="0"
			style_border_width="1"
			style_border_color="#COLOR_DIVIDER"
			style_shadow_width="8"
			style_shadow_opa="14"
			style_shadow_color="#COLOR_SHADOW"
			style_shadow_offset_y="3"
		>
			<!-- Device name -->
			<lv_label
				name="settings_device_name_title_label"
				x="18"
				y="8"
				width="150"
				text="Device name"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_PRIMARY"
				style_text_font="font_inter_12"
			/>

			<lv_label
				name="settings_device_name_value_label"
				x="210"
				y="8"
				width="190"
				text="$device_name"
				long_mode="clip"
				style_text_align="right"
				style_text_color="#COLOR_TEXT_SECONDARY"
				style_text_font="font_inter_12"
			/>

			<lv_obj
				name="settings_device_divider_1"
				x="18"
				y="27"
				width="416"
				height="1"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_DIVIDER"
				style_bg_opa="255"
				style_border_width="0"
				style_pad_all="0"
			/>

			<!-- Model -->
			<lv_label
				name="settings_device_model_title_label"
				x="18"
				y="35"
				width="150"
				text="Model"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_PRIMARY"
				style_text_font="font_inter_12"
			/>

			<lv_label
				name="settings_device_model_value_label"
				x="210"
				y="35"
				width="190"
				text="$model_name"
				long_mode="clip"
				style_text_align="right"
				style_text_color="#COLOR_TEXT_SECONDARY"
				style_text_font="font_inter_12"
			/>

			<lv_obj
				name="settings_device_divider_2"
				x="18"
				y="54"
				width="416"
				height="1"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_DIVIDER"
				style_bg_opa="255"
				style_border_width="0"
				style_pad_all="0"
			/>

			<!-- Serial -->
			<lv_label
				name="settings_device_serial_title_label"
				x="18"
				y="62"
				width="150"
				text="Serial"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_PRIMARY"
				style_text_font="font_inter_12"
			/>

			<lv_label
				name="settings_device_serial_value_label"
				x="210"
				y="62"
				width="190"
				text="$serial_number"
				long_mode="clip"
				style_text_align="right"
				style_text_color="#COLOR_TEXT_SECONDARY"
				style_text_font="font_inter_12"
			/>

			<lv_obj
				name="settings_device_divider_3"
				x="18"
				y="81"
				width="416"
				height="1"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_DIVIDER"
				style_bg_opa="255"
				style_border_width="0"
				style_pad_all="0"
			/>

			<!-- Firmware -->
			<lv_label
				name="settings_device_firmware_title_label"
				x="18"
				y="89"
				width="150"
				text="Firmware"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_PRIMARY"
				style_text_font="font_inter_12"
			/>

			<lv_label
				name="settings_device_firmware_value_label"
				x="210"
				y="89"
				width="190"
				text="$firmware_version"
				long_mode="clip"
				style_text_align="right"
				style_text_color="#COLOR_TEXT_SECONDARY"
				style_text_font="font_inter_12"
			/>
		</lv_obj>

		<!-- Display preferences card -->
		<lv_obj
			name="settings_device_display_card"
			x="0"
			y="144"
			width="452"
			height="82"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_color="#COLOR_CARD_BG"
			style_bg_opa="255"
			style_radius="16"
			style_pad_all="0"
			style_border_width="1"
			style_border_color="#COLOR_DIVIDER"
			style_shadow_width="8"
			style_shadow_opa="14"
			style_shadow_color="#COLOR_SHADOW"
			style_shadow_offset_y="3"
		>
			<lv_label
				name="settings_device_display_title_label"
				x="18"
				y="8"
				width="120"
				text="DISPLAY"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_SECONDARY"
				style_text_font="font_inter_10"
				style_text_letter_space="1"
			/>

			<!-- Brightness row -->
			<lv_label
				name="settings_device_brightness_title_label"
				x="18"
				y="31"
				width="120"
				text="Brightness"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_PRIMARY"
				style_text_font="font_inter_12"
			/>

			<lv_slider
				name="settings_device_brightness_slider"
				x="164"
				y="36"
				width="238"
				height="8"
				value="80"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_DIVIDER"
				style_bg_opa="255"
				style_radius="4"
				style_border_width="0"
				style_pad_all="0"
				style_bg_color-indicator="#COLOR_PRIMARY_GREEN"
				style_bg_opa-indicator="255"
				style_radius-indicator="4"
				style_bg_color-knob="#COLOR_CARD_BG"
				style_bg_opa-knob="255"
				style_radius-knob="10"
				style_border_width-knob="3"
				style_border_color-knob="#COLOR_PRIMARY_GREEN"
			/>

			<lv_obj
				name="settings_device_display_divider_1"
				x="18"
				y="52"
				width="416"
				height="1"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_DIVIDER"
				style_bg_opa="255"
				style_border_width="0"
				style_pad_all="0"
			/>

			<!-- Timeout row -->
			<lv_label
				name="settings_device_timeout_title_label"
				x="18"
				y="63"
				width="150"
				text="Screen timeout"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_PRIMARY"
				style_text_font="font_inter_12"
			/>

			<lv_dropdown
				name="settings_device_timeout_dropdown"
				x="282"
				y="56"
				width="120"
				height="25"
				options="30 sec&#10;60 sec&#10;120 sec&#10;Never"
				selected="0"
				symbol="img_simple_chevron_icon_1"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_PRIMARY_GREEN"
				style_bg_opa="255"
				style_radius="8"
				style_border_width="0"
				style_pad_left="10"
				style_pad_right="8"
				style_text_color="#COLOR_WHITE"
				style_text_font="font_inter_11"
				style_image_recolor-indicator="#COLOR_WHITE"
				style_image_recolor_opa-indicator="255"
			>
				<lv_dropdown-list
					style_bg_color="#COLOR_CARD_BG"
					style_bg_opa="255"
					style_radius="10"
					style_border_width="1"
					style_border_color="#COLOR_DIVIDER"
					style_text_color="#COLOR_TEXT_PRIMARY"
					style_text_font="font_inter_11"
					style_bg_color-selected="#COLOR_LIGHT_GREEN"
					style_bg_opa-selected="255"
					style_text_color-selected="#COLOR_PRIMARY_GREEN"
				/>
			</lv_dropdown>
		</lv_obj>
	</view>
</component>
